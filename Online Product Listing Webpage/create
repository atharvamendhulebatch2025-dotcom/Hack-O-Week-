<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Nashtaa.com | Shudh Desi Nashta</title>

    <link rel="stylesheet" href="style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

</head>

<body>



    <div class="video-container">

        <video autoplay muted loop playsinline>

            <source src="https://assets.mixkit.co/videos/preview/mixkit-top-view-of-a-delicious-breakfast-dish-with-eggs-13045-large.mp4" type="video/mp4">

        </video>

    </div>



    <nav class="glass-nav">

        <div class="logo">🍽️ Nashtaa<span>.com</span></div>

        <div class="nav-right">

            <span id="user-display">Welcome, Guest</span>

            <button class="icon-btn" onclick="toggleCart()"><i class="fas fa-shopping-basket"></i> <span id="cart-count">0</span></button>

        </div>

    </nav>



    <header class="hero">

        <div class="glass-panel">

            <h1>Shudh Desi Nashta</h1>

            <p>30+ Traditional Indian Breakfasts Delivered Hot</p>

            <div class="hunger-slider">

                <label>How hungry are you? <span id="h-val">50</span>%</label>

                <input type="range" id="hunger" min="0" max="100" value="50">

            </div>

        </div>

    </header>



    <div class="filter-bar glass-panel">

        <button class="filter-btn active" data-cat="All">All Items</button>

        <button class="filter-btn" data-cat="South">South Indian</button>

        <button class="filter-btn" data-cat="North">North Indian</button>

        <button class="filter-btn" data-cat="Street">Street Special</button>

        <button class="filter-btn" data-cat="Healthy">Healthy Nashta</button>

    </div>



    <main id="menu-grid" class="product-grid">

        </main>



    <div id="cart-drawer" class="glass-sidebar">

        <button class="close-btn" onclick="toggleCart()">&times;</button>

        <h2>Your Basket</h2>

        <div id="cart-items"></div>

        <div class="cart-footer">

            <h3>Total: ₹<span id="total-price">0</span></h3>

            <button class="pay-btn" onclick="processOrder()">Order Now</button>

        </div>

    </div>



    <script src="script.js"></script>



    <div id="tracking-modal" class="modal hidden">

    <div class="glass-panel tracking-card">

        <h2>🚚 Live Tracking</h2>

        <p>Order #NST-9921 is being prepared</p>

        

        <div class="tracking-container">

            <div class="step" id="step1">

                <div class="circle"><i class="fas fa-check"></i></div>

                <div class="label">Order Confirmed</div>

            </div>

            <div class="step" id="step2">

                <div class="circle"><i class="fas fa-fire"></i></div>

                <div class="label">Chef is Cooking</div>

            </div>

            <div class="step" id="step3">

                <div class="circle"><i class="fas fa-motorcycle"></i></div>

                <div class="label">Out for Delivery</div>

            </div>

            <div class="step" id="step4">

                <div class="circle"><i class="fas fa-home"></i></div>

                <div class="label">Delivered</div>

            </div>

        </div>

        <button class="btn-add" onclick="document.getElementById('tracking-modal').classList.add('hidden')">Close</button>

    </div>

</div>

</body>:root {

    --accent: #00d2ff;

    --accent-dark: #0084ff;

    --glass: rgba(255, 255, 255, 0.1);

    --border: rgba(255, 255, 255, 0.2);

}



body {

    margin: 0;

    font-family: 'Poppins', sans-serif;

    background: #050a12;

    color: white;

    overflow-x: hidden;

}



.video-container {

    position: fixed;

    top:0; left:0; width:100%; height:100%;

    z-index: -2;

    filter: brightness(0.3);

}



.video-container video { width:100%; height:100%; object-fit:cover; }



/* Glass Panels */

.glass-panel {

    background: var(--glass);

    backdrop-filter: blur(15px);

    border: 1px solid var(--border);

    border-radius: 20px;

}



.glass-nav {

    position: fixed;

    top: 0; width: 100%;

    padding: 15px 5%;

    display: flex;

    justify-content: space-between;

    align-items: center;

    z-index: 100;

    background: rgba(0,0,0,0.5);

    backdrop-filter: blur(10px);

}



.logo { font-size: 1.5rem; font-weight: 800; }

.logo span { color: var(--accent); }



.hero {

    height: 60vh;

    display: flex;

    align-items: center;

    justify-content: center;

    padding: 0 5%;

    text-align: center;

}



.hero h1 { font-size: 3.5rem; margin-bottom: 10px; text-shadow: 0 0 20px rgba(0,210,255,0.5); }



/* Product Cards */

.product-grid {

    display: grid;

    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));

    gap: 25px;

    padding: 40px 5%;

}



.card {

    padding: 15px;

    text-align: center;

    transition: 0.4s;

}



.card:hover {

    transform: translateY(-10px);

    border-color: var(--accent);

    background: rgba(255,255,255,0.15);

}



.card img {

    width: 100%;

    height: 200px;

    border-radius: 15px;

    object-fit: cover;

}



.card h3 { margin: 15px 0 5px; color: var(--accent); }



.price-tag { font-size: 1.2rem; font-weight: bold; display: block; margin-bottom: 15px; }



.btn-add {

    background: var(--accent);

    border: none;

    padding: 10px 20px;

    border-radius: 10px;

    font-weight: bold;

    cursor: pointer;

    width: 100%;

}



/* Sidebar Cart */

.glass-sidebar {

    position: fixed;

    right: -400px; top: 0;

    width: 350px; height: 100%;

    background: rgba(0,0,0,0.8);

    backdrop-filter: blur(20px);

    z-index: 200;

    padding: 30px;

    transition: 0.5s;

    border-left: 1px solid var(--border);

}



.glass-sidebar.active { right: 0; }



.filter-bar {

    display: flex;

    justify-content: center;

    gap: 10px;

    margin: 0 5%;

    padding: 15px;

}



.filter-btn {

    background: transparent;

    border: 1px solid var(--border);

    color: white;

    padding: 8px 18px;

    border-radius: 20px;

    cursor: pointer;

}



.filter-btn.active { background: var(--accent); border-color: var(--accent); color: black; }

.modal {

    position: fixed;

    inset: 0;

    background: rgba(0,0,0,0.85);

    display: flex;

    align-items: center;

    justify-content: center;

    z-index: 1000;

}



.tracking-card {

    width: 90%;

    max-width: 500px;

    padding: 40px;

    text-align: center;

}



.tracking-container {

    margin: 40px 0;

    display: flex;

    flex-direction: column;

    gap: 20px;

    align-items: flex-start;

    padding-left: 20%;

}



.step {

    display: flex;

    align-items: center;

    gap: 20px;

    opacity: 0.3;

    transition: 0.5s;

}



.step.active {

    opacity: 1;

    color: var(--accent);

}



.step .circle {

    width: 40px;

    height: 40px;

    border-radius: 50%;

    background: var(--glass);

    border: 2px solid var(--border);

    display: flex;

    align-items: center;

    justify-content: center;

}



.step.active .circle {

    border-color: var(--accent);

    box-shadow: 0 0 15px var(--accent);

}



.hidden { display: none !important; }// 1. COMBINED PRODUCT LIST (Fixed Redeclaration Error)

const products = [

    // South Indian

    { id: 1, name: "Ghee Roast Dosa", cat: "South", price: 120, img: "https://images.unsplash.com/photo-1668236543090-82eba5ee5976?w=400" },

    { id: 2, name: "Rava Idli (2 pcs)", cat: "South", price: 85, img: "https://images.unsplash.com/photo-1589301760014-d929f3979dbc?w=400" },

    { id: 3, name: "Medhu Vada", cat: "South", price: 70, img: "https://images.unsplash.com/photo-1624313511393-6997bb1f00b7?w=400" },

    { id: 4, name: "Appam with Stew", cat: "South", price: 160, img: "https://images.unsplash.com/photo-1630383249896-424e482df921?w=400" },

    { id: 5, name: "Uttapam Platter", cat: "South", price: 140, img: "https://images.unsplash.com/photo-1644831610484-9092498877f8?w=400" },

    

    // North Indian

    { id: 6, name: "Amritsari Kulcha", cat: "North", price: 180, img: "https://images.unsplash.com/photo-1601050633647-8f8f564fb332?w=400" },

    { id: 7, name: "Paneer Paratha", cat: "North", price: 130, img: "https://images.unsplash.com/photo-1606491956689-2ea8c5119c85?w=400" },

    { id: 8, name: "Chole Bhature", cat: "North", price: 150, img: "https://images.unsplash.com/photo-1626132646529-5003375a9f18?w=400" },

    { id: 9, name: "Bedmi Poori Sabzi", cat: "North", price: 120, img: "https://images.unsplash.com/photo-1610192244261-3f33de3f55e4?w=400" },

    { id: 10, name: "Gobi Paratha", cat: "North", price: 110, img: "https://images.unsplash.com/photo-1505253501701-362bb6bb320c?w=400" },



    // Street Food & Regional

    { id: 11, name: "Indori Poha", cat: "Street", price: 60, img: "https://images.unsplash.com/photo-1626500155553-6147690623d3?w=400" },

    { id: 12, name: "Vada Pav (Set of 2)", cat: "Street", price: 50, img: "https://images.unsplash.com/photo-1606491956689-2ea8c5119c85?w=400" },

    { id: 13, name: "Misal Pav", cat: "Street", price: 140, img: "https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=400" },

    { id: 14, name: "Khaman Dhokla", cat: "Street", price: 90, img: "https://images.unsplash.com/photo-1626500155553-6147690623d3?w=400" },

    { id: 15, name: "Sabudana Khichdi", cat: "Healthy", price: 110, img: "https://images.unsplash.com/photo-1621447509371-d6a93326114d?w=400" }

];



// 2. PROCEDURAL GENERATION (Filling up to 30 items)

for(let i=16; i<=30; i++) {

    products.push({

        id: i,

        name: `Nashtaa Special #${i}`,

        cat: i % 2 === 0 ? "Healthy" : "Street",

        price: 90 + (i*2),

        img: `https://loremflickr.com/400/300/indian,breakfast?random=${i}`

    });

}



// 3. UI INITIALIZATION

const menuGrid = document.getElementById('menu-grid');

let cart = [];



function displayMenu(filteredList) {

    if(!menuGrid) return; // Guard clause

    menuGrid.innerHTML = filteredList.map(p => `

        <div class="glass-panel card">

            <img src="${p.img}" alt="${p.name}">

            <h3>${p.name}</h3>

            <div style="color: #ffd700; margin-bottom:10px">★★★★★</div>

            <span class="price-tag">₹${p.price}</span>

            <button class="btn-add" onclick="addToCart(${p.id})">Add to Basket</button>

        </div>

    `).join('');

}



// Initial Load

displayMenu(products);



// 4. FILTERING LOGIC

document.querySelectorAll('.filter-btn').forEach(btn => {

    btn.addEventListener('click', (e) => {

        const activeBtn = document.querySelector('.filter-btn.active');

        if(activeBtn) activeBtn.classList.remove('active');

        

        e.target.classList.add('active');

        const cat = e.target.dataset.cat;

        const filtered = (cat === 'All' || !cat) ? products : products.filter(p => p.cat === cat);

        displayMenu(filtered);

    });

});



// 5. CART & ORDER LOGIC

function toggleCart() {

    const drawer = document.getElementById('cart-drawer');

    if(drawer) drawer.classList.toggle('active');

}



function addToCart(id) {

    const item = products.find(p => p.id === id);

    if(item) {

        cart.push(item);

        updateCartUI();

    }

}



function updateCartUI() {

    const cartCount = document.getElementById('cart-count');

    const cartItems = document.getElementById('cart-items');

    const totalPrice = document.getElementById('total-price');



    if(cartCount) cartCount.innerText = cart.length;

    

    if(cartItems) {

        cartItems.innerHTML = cart.map(item => `

            <div style="display:flex; justify-content:space-between; margin-bottom:10px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom:5px;">

                <span>${item.name}</span>

                <span>₹${item.price}</span>

            </div>

        `).join('');

    }

    

    const total = cart.reduce((sum, item) => sum + item.price, 0);

    if(totalPrice) totalPrice.innerText = total;

}



// 6. LIVE TRACKING LOGIC

function processOrder() {

    if(cart.length === 0) return alert("Basket is empty!");

    

    const trackingModal = document.getElementById('tracking-modal');

    const cartDrawer = document.getElementById('cart-drawer');



    if(trackingModal) trackingModal.classList.remove('hidden');

    if(cartDrawer) cartDrawer.classList.remove('active');

    

    startTracking();

    

    // Clear cart after starting tracking

    cart = [];

    updateCartUI();

}



function startTracking() {

    const steps = document.querySelectorAll('.step');

    // Reset steps if previously used

    steps.forEach(step => step.classList.remove('active'));

    

    let current = 0;

    const interval = setInterval(() => {

        if(current < steps.length) {

            steps[current].classList.add('active');

            current++;

        } else {

            clearInterval(interval);

            setTimeout(() => {

                alert("Food is at your door! Enjoy your Nashtaa.");

                const trackingModal = document.getElementById('tracking-modal');

                if(trackingModal) trackingModal.classList.add('hidden');

            }, 500);

        }

    }, 3000);

}



// 7. HUNGER SLIDER

const hungerInput = document.getElementById('hunger');

if(hungerInput) {

    hungerInput.addEventListener('input', (e) => {

        const valSpan = document.getElementById('h-val');

        if(valSpan) valSpan.innerText = e.target.value;

    });

}

</html>
