<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Weather Explorer with E-Bot</title>

    <link rel="stylesheet" href="style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

</head>

<body class="default-theme">

    <header>

        <h1><i class="fas fa-cloud-sun"></i> Weather Explorer</h1>

        <p>Click cities to explore weather! Chat with E-Bot for forecasts &amp; motivation 🌟</p>

    </header>



    <main class="cities-container">

        <div class="weather-card" data-city="newyork" data-condition="sunny">

            <i class="fas fa-sun condition-icon"></i>

            <h2>New York</h2>

            <p class="temp">25°C</p>

            <p class="description">Sunny</p>

            <button class="explore-btn">Explore</button>

        </div>



        <div class="weather-card" data-city="london" data-condition="rainy">

            <i class="fas fa-cloud-rain condition-icon"></i>

            <h2>London</h2>

            <p class="temp">15°C</p>

            <p class="description">Rainy</p>

            <button class="explore-btn">Explore</button>

        </div>



        <div class="weather-card" data-city="tokyo" data-condition="cloudy">

            <i class="fas fa-cloud condition-icon"></i>

            <h2>Tokyo</h2>

            <p class="temp">20°C</p>

            <p class="description">Cloudy</p>

            <button class="explore-btn">Explore</button>

        </div>

    </main>



    <!-- Forecast Popup -->

    <div id="forecast-popup" class="popup hidden">

        <div class="popup-content">

            <span class="close">&times;</span>

            <h3 id="popup-city"></h3>

            <p id="popup-forecast"></p>

        </div>

    </div>



    <!-- Responsive E-Bot -->

    <div id="e-bot" class="e-bot-closed">

        <div class="e-bot-header">

            <i class="fas fa-robot"></i>

            <span>E-Weather Bot</span>

            <i class="fas fa-chevron-down toggle-icon"></i>

        </div>

        <div class="e-bot-body hidden">

            <div class="chat-messages" id="chat-messages">

                <div class="message bot-message">

                    <strong>E-Bot:</strong> Hi explorer! 👋 Click cities to see weather. Ask me about "forecast", "history", or "motivate"! I&apos;ll track your adventure.

                </div>

            </div>

            <div class="history-section hidden" id="history-section">

                <h4><i class="fas fa-history"></i> Your Weather History</h4>

                <div id="history-list"></div>

            </div>

            <div class="chat-input-container">

                <input type="text" id="chat-input" placeholder="Type message... (history, motivate, etc.)">

                <button id="send-btn"><i class="fas fa-paper-plane"></i></button>

            </div>

            <div class="history-toggle">

                <button id="toggle-history"><i class="fas fa-list"></i> History</button>

            </div>

        </div>

    </div>



    <script src="script.js"></script>

</body>

</html>

// FIXED VERSION - Interactive E-Bot with easier toggle, auto-open, typing indicator

// Copy this to script.js if needed, or test this.



const weatherData = {

    newyork: { condition: 'sunny', temp: '25°C', description: 'Sunny', forecast: 'Clear skies! 🌞' },

    london: { condition: 'rainy', temp: '15°C', description: 'Rainy', forecast: 'Showers 🌧️' },

    tokyo: { condition: 'cloudy', temp: '20°C', description: 'Cloudy', forecast: 'Partly cloudy ☁️' }

};



let userHistory = JSON.parse(sessionStorage.getItem('weatherHistory')) || [];

let botTyping = false;



const cards = document.querySelectorAll('.weather-card');

const body = document.body;

const popup = document.getElementById('forecast-popup');

const popupCity = document.getElementById('popup-city');

const popupForecast = document.getElementById('popup-forecast');

const closePopup = document.querySelector('.close');

const eBot = document.getElementById('e-bot');

const eBotBody = document.querySelector('.e-bot-body');

const toggleIcon = document.querySelector('.toggle-icon');

const chatMessages = document.getElementById('chat-messages');

const chatInput = document.getElementById('chat-input');

const sendBtn = document.getElementById('send-btn');

const historySection = document.getElementById('history-section');

const historyList = document.getElementById('history-list');

const toggleHistory = document.getElementById('toggle-history');



let confettiCtx;



document.addEventListener('DOMContentLoaded', function() {

    console.log('E-Bot Init started');

    setupConfetti();

    setupEvents();

    updateHistoryDisplay();

    console.log('E-Bot Init complete');

});



function setupConfetti() {

    const canvas = document.createElement('canvas');

    canvas.id = 'confetti-canvas';

    canvas.style.cssText = 'position:fixed;top:0;left:0;pointer-events:none;z-index:1001;width:100%;height:100%;';

    document.body.appendChild(canvas);

    const ctx = canvas.getContext('2d');

    canvas.width = window.innerWidth;

    canvas.height = window.innerHeight;

    confettiCtx = ctx;

}



function setupEvents() {

    // FIXED: Toggle on entire bot when closed, header always

    eBot.addEventListener('click', function(e) {

        console.log('Bot click detected');

        if (!eBot.classList.contains('e-bot-open')) {

            openBot();

        }

    });



    eBot.querySelector('.e-bot-header').addEventListener('click', function(e) {

        e.stopPropagation();

        toggleBot();

    });



    cards.forEach(card => card.addEventListener('click', function() {

        exploreCity(card.dataset.city);

    }));



    sendBtn.addEventListener('click', sendMessage);

    chatInput.addEventListener('keypress', e => e.key === 'Enter' && sendMessage());



    toggleHistory.addEventListener('click', toggleHistorySection);



    closePopup.addEventListener('click', () => popup.classList.add('hidden'));

    popup.addEventListener('click', e => e.target === popup && popup.classList.add('hidden'));



    chatInput.focus();

}



function toggleBot() {

    console.log('Toggling bot');

    eBot.classList.toggle('e-bot-open');

    eBotBody.classList.toggle('hidden');

}



function openBot() {

    console.log('Opening bot');

    eBot.classList.add('e-bot-open');

    eBotBody.classList.remove('hidden');

    toggleIcon.style.transform = 'rotate(180deg)';

    chatInput.focus();

}



function exploreCity(city) {

    const data = weatherData[city];

    body.className = data.condition + '-theme';

    popupCity.textContent = data.description.toUpperCase();

    popupForecast.textContent = data.forecast;

    popup.classList.remove('hidden');



    const timestamp = new Date().toLocaleString();

    const item = { city: city.toUpperCase(), temp: data.temp, time: timestamp };

    if (!userHistory.some(h => h.city === item.city)) {

        userHistory.unshift(item);

        sessionStorage.setItem('weatherHistory', JSON.stringify(userHistory));

        updateHistoryDisplay();

        if (!eBot.classList.contains('e-bot-open')) openBot();

        setTimeout(() => addBotMessage(`Great! ${item.city} ${data.description.toLowerCase()}. History updated! ${userHistory.length}/3`), 500);

        if (userHistory.length === 3) celebrate();

    }

}



function sendMessage() {

    const msg = chatInput.value.trim();

    if (!msg) return;

    addUserMessage(msg);

    chatInput.value = '';

    chatInput.focus();



    botTyping = true;

    addTypingIndicator();

    const lower = msg.toLowerCase();

    setTimeout(() => {

        botTyping = false;

        document.querySelector('.typing-indicator')?.remove();

        if (lower.includes('history')) {

            toggleHistorySection();

            addBotMessage('Your history below! 📜');

        } else if (lower.includes('motivate')) {

            addBotMessage(`You&apos;ve explored ${userHistory.length}/3 cities! Amazing! 🌟`);

        } else {

            addBotMessage('Hi! Try "history" or "motivate". Click cities to start! 🤖');

        }

    }, 1000 + Math.random()*1000);

}



function addUserMessage(text) {

    const div = document.createElement('div');

    div.className = 'message user-message';

    div.textContent = `You: ${text}`;

    chatMessages.appendChild(div);

    scrollChat();

}



function addBotMessage(text) {

    const div = document.createElement('div');

    div.className = 'message bot-message';

    div.innerHTML = `<strong>E-Bot:</strong> ${text}`;

    chatMessages.appendChild(div);

    scrollChat();

}



function addTypingIndicator() {

    const div = document.createElement('div');

    div.className = 'message bot-message typing-indicator';

    div.innerHTML = '<strong>E-Bot:</strong> Typing<span>.</span><span>.</span><span>.</span>';

    chatMessages.appendChild(div);

    scrollChat();

}



function scrollChat() {

    chatMessages.scrollTop = chatMessages.scrollHeight;

}



function toggleHistorySection() {

    historySection.classList.toggle('hidden');

}



function updateHistoryDisplay() {

    historyList.innerHTML = userHistory.slice(0,5).map(item => `

        <div class="history-item">

            <i class="fas fa-map-marker-alt"></i>

            <div><strong>${item.city}</strong><br><small>${item.temp} - ${item.time}</small></div>

        </div>

    `).join('') || '<p style="padding:20px;color:#666">No history. Explore! 🚀</p>';

}



function celebrate() {

    addBotMessage('🎉 Weather Master! All 3 cities done! 🏆');

    // Simple confetti

    const colors = ['#ff6b6b', '#4ecdc4', '#45b7d1', '#f9ca24'];

    let pieces = 100;

    function anim() {

        confettiCtx.clearRect(0,0,confettiCtx.canvas.width,confettiCtx.canvas.height);

        for(let i=0;i<pieces;i++) {

            const x = Math.random()*confettiCtx.canvas.width;

            const y = Math.random()*confettiCtx.canvas.height - confettiCtx.canvas.height;

            confettiCtx.fillStyle = colors[Math.floor(Math.random()*4)];

            confettiCtx.fillRect(x, y, 4, 4);

        }

        pieces > 0 && (pieces--, requestAnimationFrame(anim));

    }

    anim();

}



// FIXED Interactive E-Bot - Now responds reliably

const weatherData = {

    newyork: { condition: 'sunny', temp: '25°C', description: 'Sunny', forecast: 'Clear skies ahead! Perfect day 🌞' },

    london: { condition: 'rainy', temp: '15°C', description: 'Rainy', forecast: 'Showers today ☔' },

    tokyo: { condition: 'cloudy', temp: '20°C', description: 'Cloudy', forecast: 'Partly cloudy ☁️' }

};



let userHistory = JSON.parse(sessionStorage.getItem('weatherHistory')) || [];

let botTyping = false;



document.addEventListener('DOMContentLoaded', function() {

    console.log('✅ E-Bot loading...');

    setupElements();

    updateHistory();

    console.log('✅ E-Bot ready!');

});



function setupElements() {

    const eBot = document.getElementById('e-bot');

    const chatInput = document.getElementById('chat-input');

    const sendBtn = document.getElementById('send-btn');

    const chatMessages = document.getElementById('chat-messages');

    const historyList = document.getElementById('history-list');

    const cards = document.querySelectorAll('.weather-card');

    const body = document.body;

    const popup = document.getElementById('forecast-popup');



    // Easy toggle - click anywhere on closed bot

    eBot.addEventListener('click', function(e) {

        if (!eBot.classList.contains('e-bot-open') && !e.target.closest('.e-bot-body')) {

            eBot.classList.add('e-bot-open');

            document.querySelector('.e-bot-body').classList.remove('hidden');

            document.querySelector('.toggle-icon').style.transform = 'rotate(180deg)';

            chatInput.focus();

            console.log('🔓 Bot opened');

        }

    });



    // City clicks

    cards.forEach(card => card.addEventListener('click', () => {

        const city = card.dataset.city;

        const data = weatherData[city];

        body.className = data.condition + '-theme';

        document.getElementById('popup-city').textContent = data.description.toUpperCase();

        document.getElementById('popup-forecast').textContent = data.forecast;

        popup.classList.remove('hidden');

        

        // History

        if (!userHistory.some(h => h.city === city.toUpperCase())) {

            userHistory.unshift({city: city.toUpperCase(), temp: data.temp, time: new Date().toLocaleString()});

            sessionStorage.setItem('weatherHistory', JSON.stringify(userHistory));

            updateHistory();

            addMessage(`Great! ${city.toUpperCase()} added to history (${userHistory.length}/3) 👏`, 'bot');

            if (userHistory.length === 3) confetti();

        }

        openBot();

    }));



    // Chat send

    function sendChat() {

        const msg = chatInput.value.trim();

        if (!msg) return;

        addMessage(msg, 'user');

        chatInput.value = '';

        chatInput.focus();

        

        // Typing...

        botTyping = true;

        const typingDiv = addTyping();

        setTimeout(() => {

            botTyping = false;

            typingDiv.remove();

            const lower = msg.toLowerCase();

            let response = '';

            if (lower.includes('history')) {

                response = 'Your history shown! 📜';

            } else if (lower.includes('motivate')) {

                response = `Excellent explorer! ${userHistory.length}/3 cities done 🌟`;

            } else if (lower.includes('hi') || lower.includes('hello')) {

                response = 'Hi! Ready to explore weather? 😊';

            } else {

                response = 'Try "history", "motivate" or click cities! 🤖';

            }

            addMessage(response, 'bot');

        }, 1200);

    }

    sendBtn.onclick = chatInput.onkeypress = e => (e.type === 'click' || e.key === 'Enter') && sendChat();

    

    // History toggle

    document.getElementById('toggle-history').onclick = () => historySection.classList.toggle('hidden');

}



function addMessage(text, sender) {

    const div = document.createElement('div');

    div.className = `message ${sender}-message`;

    div.innerHTML = `<strong>${sender === 'user' ? 'You' : 'E-Bot'}:</strong> ${text}`;

    document.getElementById('chat-messages').appendChild(div);

    div.scrollIntoView();

}



function addTyping() {

    const div = document.createElement('div');

    div.className = 'message bot-message';

    div.textContent = 'E-Bot: Typing';

    document.getElementById('chat-messages').appendChild(div);

    div.scrollIntoView();

    return div;

}



function updateHistory() {

    const list = document.getElementById('history-list');

    list.innerHTML = userHistory.slice(0,5).map(item => 

        `<div class="history-item"><i class="fas fa-map-marker-alt"></i>${item.city} ${item.temp}<br><small>${item.time}</small></div>`

    ).join('') || '<p>No history yet - explore cities!</p>';

}



function confetti() {

    addMessage('🎉 Weather Master! All cities explored! 🏆', 'bot');

    // Canvas confetti

    const canvas = document.getElementById('confetti-canvas') || (() => {

        const c = document.createElement('canvas');

        c.id = 'confetti-canvas';

        c.style.cssText = 'position:fixed;top:0;left:0;pointer-events:none;z-index:1001';

        document.body.appendChild(c);

        return c;

    })();

    const ctx = canvas.getContext('2d');

    canvas.width = innerWidth;

    canvas.height = innerHeight;

    let animationId;

    const animate = () => {

        ctx.clearRect(0,0,canvas.width,canvas.height);

        for(let i=0;i<100;i++) {

            ctx.fillStyle = `hsl(${Math.random()*360},70%,60%)`;

            ctx.fillRect(Math.random()*canvas.width, Math.random()*canvas.height, 6, 6);

        }

        animationId = requestAnimationFrame(animate);

    };

    animate();

    setTimeout(() => cancelAnimationFrame(animationId), 3000);

}



function openBot() {

    const eBot = document.getElementById('e-bot');

    eBot.classList.add('e-bot-open');

    document.querySelector('.e-bot-body').classList.remove('hidden');

    document.querySelector('.toggle-icon').style.transform = 'rotate(180deg)';

    document.getElementById('chat-input').focus();

}



// Close popup

document.querySelector('.close').onclick = () => document.getElementById('forecast-popup').classList.add('hidden');

* {

    margin: 0;

    padding: 0;

    box-sizing: border-box;

}



body {

    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

    min-height: 100vh;

    transition: all 0.5s ease;

    position: relative;

}



.default-theme {

    background: linear-gradient(135deg, #74b9ff, #0984e3);

    color: #333;

}



/* Sunny Theme */

body.sunny-theme {

    background: linear-gradient(135deg, #fdcb6e, #e17055, #f39c12);

}



.sunny-theme .weather-card { border-color: #f1c40f; box-shadow: 0 8px 25px rgba(241, 196, 15, 0.3); }

.sunny-theme .e-bot { border: 2px solid #f39c12; }



/* Rainy Theme */

body.rainy-theme {

    background: linear-gradient(135deg, #636e72, #2d3436, #00b894);

}



.rainy-theme .weather-card { border-color: #00b894; box-shadow: 0 8px 25px rgba(0, 184, 148, 0.3); }

.rainy-theme .e-bot { border: 2px solid #00b894; }



/* Cloudy Theme */

body.cloudy-theme {

    background: linear-gradient(135deg, #b2bec3, #636e72, #2d3436);

}



.cloudy-theme .weather-card { border-color: #95a5a6; box-shadow: 0 8px 25px rgba(149, 165, 166, 0.3); }

.cloudy-theme .e-bot { border: 2px solid #95a5a6; }



header {

    text-align: center;

    padding: 2rem;

}



header h1 {

    font-size: 3rem;

    margin-bottom: 0.5rem;

    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);

}



header p { font-size: 1.2rem; opacity: 0.9; }



.cities-container {

    display: grid;

    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));

    gap: 2rem;

    max-width: 1200px;

    margin: 2rem auto;

    padding: 0 1rem;

}



.weather-card {

    background: rgba(255,255,255,0.95);

    border-radius: 20px;

    padding: 2rem;

    text-align: center;

    transition: all 0.3s ease;

    border: 3px solid transparent;

    backdrop-filter: blur(10px);

    cursor: pointer;

}



.weather-card:hover {

    transform: translateY(-10px) scale(1.02);

    box-shadow: 0 20px 40px rgba(0,0,0,0.2);

}



.condition-icon { font-size: 4rem; margin-bottom: 1rem; opacity: 0.9; }



.weather-card h2 { font-size: 2rem; margin-bottom: 0.5rem; }



.temp { font-size: 3rem; font-weight: bold; margin: 0.5rem 0; }



.description { font-size: 1.3rem; text-transform: capitalize; }



.explore-btn {

    background: linear-gradient(45deg, #667eea, #764ba2);

    color: white;

    border: none;

    padding: 12px 30px;

    border-radius: 50px;

    font-size: 1rem;

    cursor: pointer;

    margin-top: 1rem;

    transition: all 0.3s;

}



.explore-btn:hover { transform: scale(1.05); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }



/* Popup */

.popup {

    position: fixed;

    top: 0;

    left: 0;

    width: 100%;

    height: 100%;

    background: rgba(0,0,0,0.7);

    display: flex;

    align-items: center;

    justify-content: center;

    z-index: 1000;

    animation: fadeIn 0.3s ease;

}



.popup.hidden { display: none; }



.popup-content {

    background: white;

    padding: 3rem;

    border-radius: 20px;

    text-align: center;

    max-width: 500px;

    position: relative;

    box-shadow: 0 20px 60px rgba(0,0,0,0.4);

    animation: popIn 0.4s ease;

}



.close {

    position: absolute;

    top: 15px;

    right: 20px;

    font-size: 2rem;

    cursor: pointer;

    color: #999;

}



.close:hover { color: #333; }



@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

@keyframes popIn { from { transform: scale(0.7); opacity: 0; } to { transform: scale(1); opacity: 1; } }



/* E-Bot - Responsive */

#e-bot {

    position: fixed;

    bottom: 20px;

    right: 20px;

    width: 350px;

    height: 500px;

    background: rgba(255,255,255,0.95);

    border-radius: 20px;

    box-shadow: 0 20px 60px rgba(0,0,0,0.3);

    overflow: hidden;

    transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);

    z-index: 999;

    backdrop-filter: blur(20px);

}



#e-bot.e-bot-closed { height: 60px; }



.e-bot-closed .e-bot-body { display: none; }



.e-bot-header {

    background: linear-gradient(45deg, #667eea, #764ba2);

    color: white;

    padding: 15px;

    display: flex;

    align-items: center;

    justify-content: space-between;

    cursor: pointer;

    font-weight: bold;

}



.toggle-icon {

    transition: transform 0.3s;

}



.e-bot-open .toggle-icon { transform: rotate(180deg); }



.e-bot-body {

    height: calc(100% - 60px);

    display: flex;

    flex-direction: column;

}



.chat-messages {

    flex: 1;

    padding: 20px;

    overflow-y: auto;

    background: linear-gradient(to bottom, #f8f9fa, #e9ecef);

}



.history-section {

    padding: 0 20px 20px;

    background: #f8f9fa;

}



#history-list {

    max-height: 150px;

    overflow-y: auto;

}



.history-item {

    background: linear-gradient(45deg, #667eea, #764ba2);

    color: white;

    margin: 10px 0;

    padding: 15px;

    border-radius: 15px;

    display: flex;

    align-items: center;

    animation: slideIn 0.5s ease;

    box-shadow: 0 5px 15px rgba(0,0,0,0.1);

}



.history-item i { margin-right: 10px; font-size: 1.5rem; }



@keyframes slideIn {

    from { opacity: 0; transform: translateX(20px); }

    to { opacity: 1; transform: translateX(0); }

}



.message {

    margin-bottom: 15px;

    padding: 12px 16px;

    border-radius: 20px;

    max-width: 90%;

    animation: messageSlide 0.3s ease;

}



.bot-message {

    background: linear-gradient(45deg, #a8e6cf, #81d4fa);

    margin-left: auto;

    text-align: right;

}



.user-message {

    background: linear-gradient(45deg, #667eea, #764ba2);

    color: white;

    margin-right: auto;

}



@keyframes messageSlide {

    from { opacity: 0; transform: translateY(10px); }

    to { opacity: 1; transform: translateY(0); }

}



.chat-input-container {

    padding: 20px;

    display: flex;

    gap: 10px;

    border-top: 1px solid #ddd;

    background: white;

}



#chat-input {

    flex: 1;

    padding: 12px 16px;

    border: 2px solid #e9ecef;

    border-radius: 25px;

    font-size: 1rem;

    outline: none;

    transition: border-color 0.3s;

}



#chat-input:focus { border-color: #667eea; }



#send-btn {

    background: linear-gradient(45deg, #667eea, #764ba2);

    color: white;

    border: none;

    width: 45px;

    height: 45px;

    border-radius: 50%;

    cursor: pointer;

    transition: transform 0.3s;

}



#send-btn:hover { transform: scale(1.1); }



.history-toggle {

    text-align: center;

    padding: 10px;

    background: #f8f9fa;

}



#toggle-history {

    background: none;

    border: 2px solid #667eea;

    color: #667eea;

    padding: 8px 20px;

    border-radius: 20px;

    cursor: pointer;

    transition: all 0.3s;

}



#toggle-history:hover {

    background: #667eea;

    color: white;

}



/* Confetti Canvas */

#confetti-canvas {

    position: fixed;

    top: 0;

    left: 0;

    pointer-events: none;

    z-index: 1001;

}



/* Responsive */

@media (max-width: 768px) {

    #e-bot {

        width: 90vw;

        height: 70vh;

        right: 5vw;

        bottom: 5vh;

    }



    .cities-container {

        grid-template-columns: 1fr;

        margin: 1rem;

    }



    header h1 { font-size: 2rem; }



    .popup-content { padding: 2rem 1.5rem; margin: 1rem; }

}



@media (max-width: 480px) {

    #e-bot { width: 95vw; height: 80vh; }

}
