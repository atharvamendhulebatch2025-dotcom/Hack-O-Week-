*{

margin:0;

padding:0;

box-sizing:border-box;

font-family:Arial;

}



body{

background:url("https://images.unsplash.com/photo-1441986300917-64674bd600d8");

background-size:cover;

background-attachment:fixed;

}



/* HEADER */



header{

background:rgba(0,0,0,0.7);

backdrop-filter:blur(10px);

color:white;

padding:20px;

text-align:center;

position:sticky;

top:0;

}



.cart{

position:absolute;

right:30px;

top:20px;

font-size:20px;

}



/* NAVIGATION */



nav{

margin-top:10px;

}



nav a{

color:white;

margin:10px;

text-decoration:none;

font-size:18px;

transition:0.3s;

}



nav a:hover{

color:#ff4d4d;

}



.dropdown{

display:inline-block;

position:relative;

}



.dropbtn{

background:none;

border:none;

color:white;

font-size:18px;

cursor:pointer;

margin:10px;

}



.dropdown-content{

display:none;

position:absolute;

background:white;

min-width:160px;

border-radius:8px;

overflow:hidden;

box-shadow:0 8px 20px rgba(0,0,0,0.3);

}



.dropdown-content a{

display:block;

padding:12px;

text-decoration:none;

color:black;

}



.dropdown-content a:hover{

background:#f2f2f2;

}



.dropdown:hover .dropdown-content{

display:block;

}



/* HERO */



.hero{

text-align:center;

padding:120px 20px;

color:white;

background:rgba(0,0,0,0.4);

}



.hero h2{

font-size:45px;

margin-bottom:10px;

}



.hero p{

font-size:22px;

}



/* PRODUCTS */



.title{

text-align:center;

margin-top:40px;

color:white;

font-size:32px;

}



.products{

display:flex;

flex-wrap:wrap;

justify-content:center;

padding:20px;

}



.product{

background:white;

width:240px;

margin:20px;

padding:15px;

border-radius:12px;

text-align:center;

transition:0.4s;

box-shadow:0 8px 20px rgba(0,0,0,0.2);

}



.product:hover{

transform:translateY(-10px) scale(1.05);

}



.product img{

width:100%;

height:220px;

object-fit:cover;

border-radius:10px;

}



/* BUTTON */



button{

background:#ff4d4d;

color:white;

border:none;

padding:10px 15px;

margin-top:10px;

cursor:pointer;

border-radius:6px;

transition:0.3s;

}



button:hover{

background:black;

}



/* FOOTER */



footer{

background:black;

color:white;

text-align:center;

padding:15px;

margin-top:40px;

}



let cart = 0;



function addCart(){



cart++;



document.getElementById("cart-count").innerText = cart;



alert("Item Added To Cart 🛒");



}
