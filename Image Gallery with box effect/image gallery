color:white;

text-align:center;

position:relative;

z-index:1;

}

/* GOLDEN HEADING */



.gold-heading{

font-size:50px;

font-weight:800;

letter-spacing:3px;

position:relative;



/* GOLD GRADIENT */



background:linear-gradient(

90deg,

#FFD700,

#FFC300,

#FFF8DC,

#FFD700

);



background-size:300%;

-webkit-background-clip:text;

background-clip:text;

-webkit-text-fill-color:transparent;



animation:

goldShine 4s linear infinite,

floatTitle 3s ease-in-out infinite;



/* GOLD GLOW */



text-shadow:

0 0 10px #FFD700,

0 0 20px #DAA520,

0 0 30px #B8860B;

}



/* GOLD SHINE MOVING EFFECT */



@keyframes goldShine{

0%{background-position:0%;}

100%{background-position:300%;}

}



/* FLOATING ANIMATION */



@keyframes floatTitle{

0%{transform:translateY(0px);}

50%{transform:translateY(-6px);}

100%{transform:translateY(0px);}

}



/* SPARKLE EFFECT */



.gold-heading::after{

content:"✨";

position:absolute;

right:-25px;

top:-10px;

font-size:22px;

animation:sparkle 2s infinite;

}



@keyframes sparkle{

0%{opacity:0; transform:scale(0.5);}

50%{opacity:1; transform:scale(1.2);}

100%{opacity:0; transform:scale(0.5);}

}

let images=[

"https://picsum.photos/900?random=1",

"https://picsum.photos/900?random=2",

"https://picsum.photos/900?random=3",

"https://picsum.photos/900?random=4",

"https://picsum.photos/900?random=5",

"https://picsum.photos/900?random=6",

"https://picsum.photos/900?random=7",

"https://picsum.photos/900?random=8",

"https://picsum.photos/900?random=9"

];



let currentIndex=0;



function openLightbox(index){

currentIndex=index;

document.getElementById("lightbox").style.display="flex";

showImage();

}



function closeLightbox(){

document.getElementById("lightbox").style.display="none";

}



function changeSlide(step){



currentIndex+=step;



if(currentIndex>=images.length){

currentIndex=0;

}



if(currentIndex<0){

currentIndex=images.length-1;

}



showImage();

}



function showImage(){

document.getElementById("lightbox-img").src=images[currentIndex];

document.getElementById("caption").innerText="Photo "+(currentIndex+1)+" of 9";

}

const cursorLight = document.querySelector(".cursor-light");



document.addEventListener("mousemove", function(e){



cursorLight.style.left = e.clientX + "px";

cursorLight.style.top = e.clientY + "px";



});
