.feature-box:hover {

    transform: translateY(-8px) scale(1.02);

    box-shadow: 0 14px 30px rgba(0,0,0,0.18);

}



/* Counter Box Hover */

.counter-box {

    transition: transform 0.3s ease, box-shadow 0.3s ease;

}



.counter-box:hover {

    transform: translateY(-6px);

    box-shadow: 0 14px 28px rgba(0,0,0,0.2);

}



/* Review Card Hover */

.review-card {

    transition: transform 0.3s ease, box-shadow 0.3s ease;

}



.review-card:hover {

    transform: translateY(-6px);

    box-shadow: 0 12px 26px rgba(0,0,0,0.15);

}



/* Contact Section */

.contact {

    padding: 80px 20px;

    background: #fff;

}



/* Header */

.contact-header {

    text-align: center;

    max-width: 750px;

    margin: 0 auto 50px;

}



.contact-tag {

    display: inline-block;

    background: #ff4400;

    color: white;

    padding: 6px 16px;

    border-radius: 20px;

    font-size: 13px;

    margin-bottom: 10px;

}



.contact-header h2 {

    font-size: 36px;

    margin: 10px 0;

    color: #000000;

}



.contact-line {

    width: 90px;

    height: 4px;

    background: #ff6f00;

    margin: 12px auto;

    border-radius: 2px;

}



.contact-header p {

    font-size: 16px;

    color: #000000;

    line-height: 1.7;

}



/* Content Layout */

.contact-content {

    display: grid;

    grid-template-columns: 1fr 1fr;

    gap: 40px;

    max-width: 1100px;

    margin: auto;

}



/* Contact Info */

.contact-info {

    display: grid;

    grid-template-columns: repeat(2, 1fr);

    gap: 20px;

}



.info-box {

    background: #fff7f0;

    padding: 25px 20px;

    border-radius: 16px;

    box-shadow: 0 6px 18px rgba(0,0,0,0.08);

}



.info-box h3 {

    font-size: 18px;

    margin-bottom: 8px;

}



.info-box p {

    font-size: 15px;

    color: #555;

}



/* Contact Form */

.contact-form {

    background: #fff;

    padding: 30px 25px;

    border-radius: 20px;

    box-shadow: 0 8px 22px rgba(0,0,0,0.08);

}



.contact-form h3 {

    margin-bottom: 20px;

    font-size: 22px;

    color: #333;

}



.contact-form input,

.contact-form textarea {

    width: 100%;

    padding: 12px 14px;

    margin-bottom: 15px;

    border-radius: 10px;

    border: 1px solid #ddd;

    font-size: 14px;

}



.contact-form input:focus,

.contact-form textarea:focus {

    outline: none;

    border-color: #ff6f00;

}



.contact-form button {

    width: 100%;

    padding: 12px;

    border: none;

    border-radius: 12px;

    background: #ff6f00;

    color: white;

    font-size: 16px;

    cursor: pointer;

    transition: 0.3s;

}



.contact-form button:hover {

    background: #e65c00;

}



/* Responsive */

@media (max-width: 768px) {

    .contact-content {

        grid-template-columns: 1fr;

    }



    .contact-info {

        grid-template-columns: 1fr;

    }

}



/* Contact Info Card Hover */

.info-box {

    transition: transform 0.3s ease, box-shadow 0.3s ease;

}



.info-box:hover {

    transform: translateY(-6px);

    box-shadow: 0 12px 25px rgba(0,0,0,0.15);

}



/* Contact Form Hover */

.contact-form {

    transition: transform 0.3s ease, box-shadow 0.3s ease;

}



.contact-form:hover {

    transform: translateY(-4px);

    box-shadow: 0 14px 30px rgba(0,0,0,0.15);

}



/* Input Focus Glow */

.contact-form input:focus,

.contact-form textarea:focus {

    box-shadow: 0 0 0 3px rgba(255, 111, 0, 0.2);

}



/* Button Hover Effect */

.contact-form button {

    transition: background 0.3s ease, transform 0.2s ease;

}



.contact-form button:hover {

    background: #e65c00;

    transform: scale(1.03);

}





